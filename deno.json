{
  "tasks": {
    "render": "deno run --unstable-webgpu -A src/main.js",
    "tree-shadow": "deno run -A tools/tree-shadow.js",
    "validate": "deno run --unstable-webgpu -A tools/validate.js",
    "validate:blur": "deno run -A tools/validate-blur.js",
    "validate:shadow": "deno run -A tools/validate-shadow-kernel.js",
    "serve": "deno run -A jsr:@std/http@^1/file-server --port 8080 .",
    "cert": "deno run -A tools/gen-cert.js",
    "serve:https": "deno run -A tools/gen-cert.js && deno run -A jsr:@std/http@^1/file-server --port 8080 --cert cert.pem --key key.pem ."
  },
  "imports": {
    "png-tools": "npm:png-tools@^1.0.4",
    "opentype.js": "npm:opentype.js@1.3.5",
    "@napi-rs/canvas": "npm:@napi-rs/canvas@^0.1.100"
  },
  "fmt": {
    "lineWidth": 110,
    "singleQuote": true,
    "semiColons": true,
    "proseWrap": "preserve"
  }
}
